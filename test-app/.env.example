# Payd API credentials (from your Payd dashboard)
PAYD_API_USERNAME=
PAYD_API_PASSWORD=

# Your Payd account username (used in request bodies)
PAYD_USERNAME=

# Webhook receiver URL (auto-set to local server if empty)
PAYD_CALLBACK_URL=http://localhost:3456/api/webhooks/receive

# Server port
PORT=3456
