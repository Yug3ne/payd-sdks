{
  "name": "payd-sdk-test-app",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Interactive test dashboard for the payd-node-sdk",
  "scripts": {
    "build": "esbuild public/app.js --bundle --minify --outfile=public/app.min.js",
    "prestart": "npm run build",
    "start": "node server.js",
    "dev": "npm run build && node --watch server.js"
  },
  "dependencies": {
    "express": "^5.1.0",
    "payd-node-sdk": "^0.1.2"
  },
  "devDependencies": {
    "esbuild": "^0.28.0"
  }
}
